// ------------- npx prisma db push -------------
// Quickly sync schema with the database without creating migration files.
// Good for rapid development, but avoid using in production.

// ------------- npx prisma migrate dev --name add_hashed_refresh_token -------------
// Create a migration file and apply it to the database.
// Keeps schema history and is safer for long-term projects.


generator client {
  provider        = "prisma-client"
  output          = "../generated/prisma"
  moduleFormat    = "cjs"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  STAFF
  MANAGER
}

model User {
  id                    Int        @id @default(autoincrement())
  fullname              String     
  email                 String     @unique
  password              String
  role                  UserRole   @default(STAFF)
  hashedRefreshToken    String?     
  createdAt             DateTime   @default(now())
  updatedAt             DateTime   @updatedAt

  savingsBooks          SavingsBook[]
  transactions          Transaction[]
}

enum BookStatus {
  OPEN
  CLOSED
}

model SavingsType {
  id              Int           @id @default(autoincrement())
  name            String        // "Không kỳ hạn", "3 tháng", "6 tháng"
  termMonths      Int           // 0 = không kỳ hạn, 3, 6
  interestRate    Float         // lãi đúng hạn (%), vd: 5.0, 5.5
  minWithdrawDays Int           // số ngày tối thiểu trước khi rút, 0 nếu có kỳ hạn, 15 nếu không kỳ hạn
  minInitDeposit  Float         // tiền gởi ban đầu tối thiểu, vd: 1_000_000
  minAddDeposit   Float         // tiền gởi thêm tối thiểu, vd: 100_000
  isActive        Boolean       @default(true)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  
  savingsBooks    SavingsBook[]
}

model Customer {
  id           Int           @id @default(autoincrement())
  fullName     String
  idNumber     String        @unique
  address      String
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  savingsBooks SavingsBook[]
}

model SavingsBook {
  id             Int              @id @default(autoincrement())
  customerId     Int    
  savingsTypeId  Int    
  openDate       DateTime
  balance        Float
  status         BookStatus       @default(OPEN)
  openedBy       Int
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  customer       Customer         @relation(fields: [customerId], references: [id])
  savingsType    SavingsType      @relation(fields: [savingsTypeId], references: [id])
  openedByUser   User             @relation(fields: [openedBy], references: [id])
  transactions   Transaction[]    
}

enum TransactionType {
  INITIAL_DEPOSIT  // gởi ban đầu khi mở sổ
  DEPOSIT          // gởi thêm (BM2)
  WITHDRAWAL       // rút tiền (BM3)
}

model Transaction {
  id              Int             @id @default(autoincrement())
  savingsBookId   Int
  type            TransactionType
  amount          Float           // số tiền gởi hoặc rút (không tính lãi)
  transactionDate DateTime        // ngày giao dịch thực tế (do user nhập)
  interest        Float?          // lãi tính được, chỉ có giá trị khi type = WITHDRAWAL
  note            String?         // ghi chú tuỳ chọn
  performedBy     Int
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  savingsBook     SavingsBook     @relation(fields: [savingsBookId], references: [id])
  performedByUser User            @relation(fields: [performedBy], references: [id])
}
